
@{
    ViewData["Title"] = "Registro";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chronos - Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f0f4ff; display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; }
        .card { border-radius: 20px; border: none; box-shadow: 0 8px 32px rgba(59,130,246,0.15); padding: 40px; width: 100%; max-width: 420px; }
        .btn-primary { background: #3b82f6; border: none; border-radius: 12px; padding: 12px; font-size: 16px; }
        .form-control { border-radius: 12px; padding: 12px; border: 1.5px solid #e2e8f0; }
    </style>
</head>
<body>
    <div class="card">
        <h2 class="fw-bold text-primary mb-1">Crear cuenta</h2>
        <p class="text-muted mb-4">Únete a Chronos</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-3">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <input name="Nombre" type="text" class="form-control" placeholder="Nombre" required />
            </div>
            <div class="mb-3">
                <input name="Apellido" type="text" class="form-control" placeholder="Apellido" required />
            </div>
            <div class="mb-3">
                <input name="Carrera" type="text" class="form-control" placeholder="Carrera" required />
            </div>
            <div class="mb-3">
                <input name="FechaNacimiento" type="date" class="form-control" required />
            </div>
            <div class="mb-3">
                <input name="Email" type="email" class="form-control" placeholder="Correo electrónico" required />
            </div>
            <div class="mb-3">
                <input name="password" type="password" class="form-control" placeholder="Contraseña" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Crear cuenta</button>
        </form>
        <p class="text-center mt-3 text-muted">¿Ya tienes cuenta? <a href="/Account/Login" class="text-primary fw-bold">Inicia sesión</a></p>
    </div>
</body>
</html>

