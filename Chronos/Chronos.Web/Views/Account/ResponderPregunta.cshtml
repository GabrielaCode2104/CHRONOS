@model Chronos.Web.Models.RecuperarPasswordViewModel
@{
    ViewData["Title"] = "Pregunta secreta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chronos - Pregunta secreta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                background: #f8faff;
        }</style>
    </head>
    <body>
        <div class="d-flex justify-content-center align-items-center min-vh-100">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="width:100%;max-width:420px">
                <h4 class="fw-bold mb-1 text-center">🔐 Pregunta secreta</h4>
                <p class="text-muted text-center small mb-4">Paso 1 de 2 — Verifica tu identidad</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger rounded-3 small">❌ @ViewBag.Error</div>
                }

                <form method="post" action="/Account/VerificarRespuesta">
                    <input type="hidden" name="Email" value="@Model.Email" />
                    <input type="hidden" name="PreguntaSecreta" value="@Model.PreguntaSecreta" />

                    <div class="alert alert-info rounded-3 small mb-3">
                        🤔 <strong>Tu pregunta:</strong> @Model.PreguntaSecreta
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Tu respuesta secreta</label>
                        <input name="RespuestaSecreta" type="password" class="form-control rounded-3"
                               placeholder="Escribe tu respuesta..." />
                    </div>

                    <button type="submit" class="btn btn-primary rounded-3 w-100">
                        Verificar respuesta →
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Account/Login" class="text-muted small">← Volver al inicio de sesión</a>
                </div>
            </div>
        </div>
    </body>
</html>