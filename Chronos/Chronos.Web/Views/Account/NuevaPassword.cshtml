@model Chronos.Web.Models.RecuperarPasswordViewModel
@{
    ViewData["Title"] = "Nueva contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chronos - Nueva contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                background: #f8faff;
        }</style>
    </head>
    <body>
        <div class="d-flex justify-content-center align-items-center min-vh-100">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="width:100%;max-width:420px">
                <h4 class="fw-bold mb-1 text-center">🔒 Nueva contraseña</h4>
                <p class="text-muted text-center small mb-4">Paso 2 de 2 — Elige tu nueva contraseña</p>

                <div class="alert alert-success rounded-3 small mb-4">
                    ✅ Identidad verificada correctamente.
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger rounded-3 small">❌ @ViewBag.Error</div>
                }

                <form method="post" action="/Account/ResetearPassword">
                    <input type="hidden" name="Email" value="@Model.Email" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Nueva contraseña</label>
                        <input name="PasswordNueva" type="password" class="form-control rounded-3"
                               placeholder="Mínimo 6 caracteres" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Confirmar nueva contraseña</label>
                        <input name="PasswordConfirmar" type="password" class="form-control rounded-3"
                               placeholder="Repite la nueva contraseña" />
                    </div>

                    <button type="submit" class="btn btn-primary rounded-3 w-100">
                        🔒 Restablecer contraseña
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Account/Login" class="text-muted small">← Volver al inicio de sesión</a>
                </div>
            </div>
        </div>
    </body>
</html>