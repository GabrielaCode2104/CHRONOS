@model Chronos.Web.Models.RecuperarPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chronos - Recuperar contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                background: #f8faff;
            }
    </style>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="card border-0 shadow-sm rounded-4 p-4" style="width:100%;max-width:420px">
            <h4 class="fw-bold mb-1 text-center">🔑 Recuperar contraseña</h4>
            <p class="text-muted text-center small mb-4">Ingresa tu correo para buscar tu cuenta</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger rounded-3 small">❌ @ViewBag.Error</div>
            }

            <form method="post" action="/Account/BuscarCuenta">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Correo electrónico</label>
                    <input asp-for="Email" class="form-control rounded-3"
                           placeholder="tucorreo@ejemplo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary rounded-3 w-100">
                    Buscar mi cuenta
                </button>
            </form>

            <div class="text-center mt-3">
                <a href="/Account/Login" class="text-muted small">← Volver al inicio de sesión</a>
            </div>
        </div>
    </div>
</body>
</html>
