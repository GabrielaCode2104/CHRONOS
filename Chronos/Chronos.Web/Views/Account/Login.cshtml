@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chronos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #f0f4ff; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; font-family: 'Segoe UI', sans-serif; }
        .logo-circle { width: 72px; height: 72px; background: #3b82f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
        .app-title { color: #3b82f6; font-size: 2rem; font-weight: 800; text-align: center; letter-spacing: 2px; }
        .app-sub { color: #94a3b8; font-size: 0.95rem; text-align: center; margin-bottom: 32px; }
        .form-wrap { width: 100%; max-width: 380px; padding: 0 24px; }
        .input-group-custom { background: white; border-radius: 14px; padding: 14px 18px; margin-bottom: 14px; display: flex; align-items: center; gap: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1.5px solid #e2e8f0; }
        .input-group-custom input { border: none; outline: none; width: 100%; font-size: 1rem; color: #1e293b; background: transparent; }
        .input-group-custom input::placeholder { color: #94a3b8; }
        .btn-login { background: #3b82f6; color: white; border: none; border-radius: 14px; width: 100%; padding: 14px; font-size: 1rem; font-weight: 600; margin-top: 8px; cursor: pointer; transition: background 0.2s; }
        .btn-login:hover { background: #2563eb; }
        .register-link { text-align: center; margin-top: 20px; color: #64748b; font-size: 0.9rem; }
        .register-link a { color: #3b82f6; font-weight: 600; text-decoration: none; }
        .forgot-link { text-align: center; margin-top: 10px; font-size: 0.85rem; }
        .forgot-link a { color: #94a3b8; text-decoration: none; }
        .forgot-link a:hover { color: #3b82f6; }
        .alert-err { background: #fee2e2; color: #dc2626; border-radius: 10px; padding: 10px 16px; margin-bottom: 14px; font-size: 0.9rem; }
        @if (TempData["Exito"] != null)
        {
            <text>.alert-ok { background: #dcfce7; color: #16a34a; border-radius: 10px; padding: 10px 16px; margin-bottom: 14px; font-size: 0.9rem; }</text>
        }
    </style>
</head>
<body>
    <div class="logo-circle">
        <svg width="38" height="38" fill="white" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 11H7v-2h4V7h2z"/></svg>
    </div>
    <div class="app-title">CHRONOS</div>
    <div class="app-sub">Organiza tu tiempo, alcanza tus metas</div>

    <div class="form-wrap">
        @if (TempData["Exito"] != null)
        {
            <div style="background:#dcfce7;color:#16a34a;border-radius:10px;padding:10px 16px;margin-bottom:14px;font-size:0.9rem;">
                ✅ @TempData["Exito"]
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert-err">@ViewBag.Error</div>
        }
        <form method="post" action="/Account/Login">
            <div class="input-group-custom">
                <span>✉️</span>
                <input name="email" type="email" placeholder="Correo electrónico" required />
            </div>
            <div class="input-group-custom">
                <span>🔒</span>
                <input name="password" type="password" placeholder="Contraseña" required />
            </div>
            <button type="submit" class="btn-login">Iniciar sesión</button>
        </form>
        <div class="forgot-link">
            <a href="/Account/RecuperarPassword">¿Olvidaste tu contraseña?</a>
        </div>
        <div class="register-link">¿No tienes cuenta? <a href="/Account/Registro">Regístrate</a></div>
    </div>
</body>
</html>