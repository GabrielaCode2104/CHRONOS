<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chronos - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            body {
                background: #f8faff;
            }

            .navbar-brand {
                color: #3b82f6 !important;
                font-weight: 800;
                font-size: 1.4rem;
            }

            .nav-link {
                color: #64748b !important;
                font-size: 0.85rem;
            }

                .nav-link.active {
                    color: #3b82f6 !important;
                    font-weight: 600;
                }

            .navbar {
                border-bottom: 1px solid #e2e8f0;
                background: white !important;
            }
    </style>
</head>
<body>
    @if (Context.Session.GetInt32("UsuarioId") != null)
    {
        <nav class="navbar navbar-expand px-4 py-2">
            <a class="navbar-brand" href="/Dashboard/Index">CHRONOS</a>
            <div class="navbar-nav mx-auto gap-4">
                <a class="nav-link @(ViewData["Title"]?.ToString() == "Inicio" ? "active" : "")" href="/Dashboard/Index">🏠 Inicio</a>
                <a class="nav-link @(ViewData["Title"]?.ToString() == "Tareas" ? "active" : "")" href="/Tareas/Index">✅ Tareas</a>
                <a class="nav-link @(ViewData["Title"]?.ToString() == "Exámenes" ? "active" : "")" href="/Examenes/Index">📝 Exámenes</a>
            </div>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Mi Perfil" ? "active" : "")" href="/Perfil/Index">👤 Perfil</a>
            <a class="nav-link text-danger ms-3" href="/Account/Logout">Cerrar sesión</a>
        </nav>
    }

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>